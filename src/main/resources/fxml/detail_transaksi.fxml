<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootVBox" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
      prefHeight="825.0" prefWidth="719.0" spacing="0.0" 
      styleClass="detail-root" 
      stylesheets="@../styles/detail_transaksi.css" 
      xmlns="http://javafx.com/javafx/26" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.projectuas.DetailTransaksiController">
    <children>
        <!-- ── HEADER PELANGGAN ── -->
        <HBox alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="719.0" 
              spacing="15.0" styleClass="header-box">
            <children>
                <Label styleClass="lbl-pelanggan" text="Pelanggan" />
                <TextField fx:id="tfPelanggan" prefHeight="40.0"
                           promptText="Masukkan nama pelanggan..." 
                           styleClass="tf-pelanggan" HBox.hgrow="ALWAYS" />
            </children>
            <padding>
                <Insets bottom="20.0" left="28.0" right="28.0" top="20.0" />
            </padding>
        </HBox>
        <!-- ── SCROLL LIST ITEM ── -->
        <ScrollPane fx:id="detailScroll" fitToWidth="true" 
                    styleClass="detail-scroll" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="12.0" left="18.0" right="18.0" top="12.0" />
            </padding>
        </ScrollPane>
        <!-- ── SUMMARY ── -->
        <VBox styleClass="summary-section">
            <padding>
                <Insets bottom="16" left="30" right="30" top="16" />
            </padding>
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="summary-label" text="Subtotal" HBox.hgrow="ALWAYS" />
                <Label fx:id="lblSubtotal" styleClass="summary-value" text="Rp 0" />
            </HBox>
            <HBox alignment="CENTER_LEFT" />
            <Separator styleClass="summary-sep" />
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="total-label" text="TOTAL" HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotal" styleClass="total-value" text="Rp 0" />
            </HBox>
        </VBox>
        <!-- ── FOOTER BUTTONS ── -->
        <HBox prefHeight="100.0" prefWidth="719.0" spacing="16.0" styleClass="footer-box">
            <children>
                <Button fx:id="btnSimpan" maxWidth="Infinity" mnemonicParsing="false" 
                        onAction="#onSimpanTransaksi" prefHeight="56.0"
                        styleClass="btn-simpan" text="💾  Simpan Transaksi" 
                        HBox.hgrow="ALWAYS" />
                <Button fx:id="btnBatal" maxWidth="Infinity" mnemonicParsing="false" 
                        onAction="#onBatalTransaksi" prefHeight="56.0"
                        styleClass="btn-batal" text="✕  Batalkan Transaksi" 
                        HBox.hgrow="ALWAYS" />
            </children>
            <padding>
                <Insets bottom="20.0" left="28.0" right="28.0" top="20.0" />
            </padding>
        </HBox>
    </children>
</VBox>