<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="900" prefWidth="1200" styleClass="root-pane" stylesheets="@../styles/barang.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.projectuas.BarangController">
  <left>
    <VBox fx:id="sidebar" minWidth="60" prefWidth="220" styleClass="sidebar">
      <HBox fx:id="logoRow" alignment="CENTER_LEFT" spacing="10" styleClass="logo-row">
        <Label styleClass="logo-icon" text="🏪"/>
        <VBox fx:id="logoBrand" spacing="1" styleClass="logo-brand">
          <Label styleClass="logo-title" text="StoreMS"/>
          <Label styleClass="logo-sub" text="Manajemen Toko"/>
        </VBox>
      </HBox>
      <Separator styleClass="sidebar-divider"/>
      <VBox fx:id="navMenu" spacing="2" styleClass="nav-menu" VBox.vgrow="ALWAYS">
        <VBox.margin>
          <Insets bottom="10" top="10"/>
        </VBox.margin>
        <HBox fx:id="navDashboard" alignment="CENTER_LEFT" onMouseClicked="#onNavDashboard" spacing="10" styleClass="nav-item">
          <Rectangle height="0" styleClass="nav-active-bar-hidden" width="3"/>
          <Label styleClass="nav-icon" text="⊞"/>
          <Label fx:id="navLblDashboard" styleClass="nav-label" text="Dashboard"/>
        </HBox>
        <HBox fx:id="navProduk" alignment="CENTER_LEFT" onMouseClicked="#onNavProduk" spacing="10" styleClass="nav-item, nav-active">
          <Rectangle height="0" styleClass="nav-active-bar" width="3"/>
          <Label styleClass="nav-icon" text="📦"/>
          <Label fx:id="navLblProduk" styleClass="nav-label" text="Produk"/>
        </HBox>
        <HBox fx:id="navKasir" alignment="CENTER_LEFT" onMouseClicked="#onNavKasir" spacing="10" styleClass="nav-item">
          <Rectangle height="0" styleClass="nav-active-bar-hidden" width="3"/>
          <Label styleClass="nav-icon" text="🛒"/>
          <Label fx:id="navLblKasir" styleClass="nav-label" text="Transaksi"/>
        </HBox>
        <HBox fx:id="navPelanggan" alignment="CENTER_LEFT" onMouseClicked="#onNavPelanggan" spacing="10" styleClass="nav-item">
          <Rectangle height="0" styleClass="nav-active-bar-hidden" width="3"/>
          <Label styleClass="nav-icon" text="👥"/>
          <Label fx:id="navLblPelanggan" styleClass="nav-label" text="Pelanggan"/>
        </HBox>
        <HBox fx:id="navLaporan" alignment="CENTER_LEFT" onMouseClicked="#onNavLaporan" spacing="10" styleClass="nav-item">
          <Rectangle height="0" styleClass="nav-active-bar-hidden" width="3"/>
          <Label styleClass="nav-icon" text="📈"/>
          <Label fx:id="navLblLaporan" styleClass="nav-label" text="Laporan"/>
        </HBox>
        <HBox fx:id="navPiutang" alignment="CENTER_LEFT" onMouseClicked="#onNavPiutang" spacing="10" styleClass="nav-item">
          <Rectangle height="0" styleClass="nav-active-bar-hidden" width="3"/>
          <Label styleClass="nav-icon" text="💰"/>
          <Label fx:id="navLblPengaturan" styleClass="nav-label" text="Piutang"/>
        </HBox>
        <HBox fx:id="navPengaturan" alignment="CENTER_LEFT" onMouseClicked="#onNavPengaturan" spacing="10" styleClass="nav-item">
          <Rectangle height="0" styleClass="nav-active-bar-hidden" width="3"/>
          <Label styleClass="nav-icon" text="⚙️"/>
          <Label fx:id="navLblPengaturan1" styleClass="nav-label" text="Pengaturan"/>
        </HBox>
      </VBox>
      <Separator styleClass="sidebar-divider"/>
      <HBox fx:id="userRow" alignment="CENTER_LEFT" spacing="8" styleClass="user-row">
        <Label styleClass="user-avatar" text="A"/>
        <VBox fx:id="userInfo" spacing="1">
          <Label styleClass="user-name" text="Admin"/>
          <Label styleClass="user-role" text="Administrator"/>
        </VBox>
      </HBox>
      <Button fx:id="toggleBtn" maxWidth="Infinity" onAction="#onToggleSidebar" styleClass="toggle-btn" text="◀"/>
    </VBox>
  </left>

  <center>
    <VBox styleClass="main-content">
      <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
        <VBox spacing="1" HBox.hgrow="ALWAYS">
          <Label styleClass="page-title" text="Produk"/>
          <Label styleClass="page-date" text="Senin, 16 Juni 2025"/>
        </VBox>
        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="search-box">
          <Label styleClass="search-icon" text="🔍"/>
          <TextField promptText="Cari..." styleClass="search-field"/>
        </HBox>
        <StackPane styleClass="notif-wrapper">
          <Button styleClass="notif-btn" text="🔔"/>
          <Label styleClass="notif-badge" text="" StackPane.alignment="TOP_RIGHT"/>
        </StackPane>
        <Label styleClass="topbar-avatar" text="A"/>
      </HBox>
      <ScrollPane fitToWidth="true" styleClass="body-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="20" styleClass="body-content">
          <padding>
            <Insets bottom="20" left="20" right="20" top="20"/>
          </padding>
          <VBox spacing="20.0" styleClass="form-card">
            <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Form Data Produk"/>
            <HBox spacing="15.0">
              <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="NAMA BARANG"/>
                <TextField fx:id="txtNama" promptText="Masukkan nama barang..." styleClass="form-field"/>
              </VBox>
              <VBox prefWidth="300.0" spacing="5">
                <Label styleClass="form-label" text="KATEGORI"/>
                <ComboBox fx:id="cmbKategori" prefWidth="300.0" promptText="Pilih Kategori" styleClass="form-field"/>
              </VBox>
            </HBox>
            <HBox spacing="15.0">
              <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="HARGA JUAL (RP)"/>
                <TextField fx:id="txtHarga" promptText="Contoh: 5000" styleClass="form-field"/>
              </VBox>
              <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="JUMLAH STOK"/>
                <TextField fx:id="txtStok" promptText="0" styleClass="form-field"/>
              </VBox>
              <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="FOTO PRODUK"/>
                <HBox spacing="8.0">
                  <Button onAction="#onPilihFoto" style="-fx-background-color: #252840; -fx-text-fill: white; -fx-border-color: #2E3250; -fx-border-radius: 8; -fx-background-radius: 8;" text="Pilih File..."/>
                  <Label fx:id="lblFilePath" prefHeight="35.0" style="-fx-text-fill: #8B8FA8; -fx-padding: 8 0 0 5;" text="Tidak ada file dipilih"/>
                </HBox>
              </VBox>
            </HBox>
            <VBox spacing="5">
              <Label styleClass="form-label" text="DESKRIPSI PRODUK"/>
              <TextArea fx:id="txtDeskripsi" prefHeight="75.0" promptText="Keterangan pelengkap barang..." styleClass="form-field" wrapText="true"/>
            </VBox>
            <HBox alignment="TOP_RIGHT" spacing="10.0">
              <Button onAction="#tambahBarang" styleClass="btn-primary" text="Simpan (Create)"/>
              <Button onAction="#ubahBarang" style="-fx-background-color: #FFD166; -fx-text-fill: #1A1D2E;" styleClass="btn-primary" text="Update"/>
              <Button onAction="#hapusBarang" styleClass="btn-danger" text="Hapus (Delete)"/>
              <Button onAction="#clearForm" style="-fx-background-color: transparent; -fx-text-fill: #8B8FA8; -fx-border-color: #2E3250; -fx-border-radius: 8;" styleClass="btn-primary" text="Reset"/>
            </HBox>
          </VBox>
          <TableView fx:id="tabelBarang" prefHeight="480.0" styleClass="barang-table" VBox.vgrow="ALWAYS">
            <columns>
              <TableColumn fx:id="colId" prefWidth="50.0" text="ID"/>
              <TableColumn fx:id="colGambar" prefWidth="100.0" text="Gambar"/>
              <TableColumn fx:id="colNama" prefWidth="200.0" text="Nama Barang"/>
              <TableColumn fx:id="colKategori" prefWidth="140.0" text="Kategori"/>
              <TableColumn fx:id="colHarga" prefWidth="120.0" text="Harga Jual"/>
              <TableColumn fx:id="colStok" prefWidth="90.0" text="Stok"/>
              <TableColumn fx:id="colDeskripsi" prefWidth="240.0" text="Deskripsi Singkat"/>
              <TableColumn fx:id="colStatus" prefWidth="130.0" text="Status Stok"/>
            </columns>
          </TableView>
        </VBox>
      </ScrollPane>
    </VBox>
  </center>
</BorderPane>
