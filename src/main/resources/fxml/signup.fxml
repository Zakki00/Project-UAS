<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<StackPane styleClass="signup-root" stylesheets="@../styles/signup.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.projectuas.SignupController">
  <!-- Background dekorasi -->
  <Rectangle arcHeight="400" arcWidth="400" height="400" styleClass="bg-circle-1" width="400" />
  <Rectangle arcHeight="300" arcWidth="300" height="300" styleClass="bg-circle-2" width="300" StackPane.alignment="BOTTOM_RIGHT" />
  <!-- Card utama -->
  <VBox maxHeight="620" maxWidth="440" spacing="0" styleClass="signup-card" StackPane.alignment="CENTER">
    <!-- Header -->
    <VBox alignment="CENTER" spacing="6" styleClass="signup-header">
      <padding>
        <Insets bottom="24" left="36" right="36" top="36" />
      </padding>
      <Label styleClass="signup-logo" text="🏪" />
      <Label styleClass="signup-title" text="Buat Akun Baru" />
      <Label styleClass="signup-sub" text="Daftarkan diri Anda " />
    </VBox>
    <!-- Form -->
    <VBox spacing="16" styleClass="signup-form">
      <padding>
        <Insets bottom="24" left="36" right="36" top="8" />
      </padding>
      <!-- Nama Lengkap -->
      <VBox spacing="6">
        <Label fx:id="errNama" managed="false" styleClass="field-error" text="" visible="false" />
      </VBox>
      <!-- nama -->
       <VBox spacing="6">
        <Label styleClass="field-label" text="Nama" />
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="field-box">
          <Label styleClass="field-icon" text="👤" />
          <TextField fx:id="tfnama" promptText="Masukkan nama..." styleClass="field-input" HBox.hgrow="ALWAYS" />
        </HBox>
        <Label fx:id="errnama" managed="false" styleClass="field-error" text="" visible="false" />
      </VBox>
      <!-- Username -->
      <VBox spacing="6">
        <Label styleClass="field-label" text="Username" />
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="field-box">
          <Label styleClass="field-icon" text="👤" />
          <TextField fx:id="tfUsername" promptText="Masukkan username..." styleClass="field-input" HBox.hgrow="ALWAYS" />
        </HBox>
        <Label fx:id="errUsername" managed="false" styleClass="field-error" text="" visible="false" />
      </VBox>
      <!-- Password -->
      <VBox spacing="6">
        <Label styleClass="field-label" text="Password" />
        <HBox fx:id="boxPassword" alignment="CENTER_LEFT" spacing="10" styleClass="field-box">
          <Label styleClass="field-icon" text="🔒" />
          <PasswordField fx:id="pfPassword" promptText="Masukkan password..." styleClass="field-input" HBox.hgrow="ALWAYS" />
          <Button fx:id="btnShowPass" onAction="#onTogglePassword" styleClass="btn-eye" text="👁" />
        </HBox>
        <Label fx:id="errPassword" managed="false" styleClass="field-error" text="" visible="false" />
      </VBox>
         <Button fx:id="loginBtn" maxWidth="Infinity" onAction="#handleLogin" styleClass="login-btn" text="Daftarkan Akun" />
       <!-- Footer -->
       <HBox fx:id="boxmasuksekarang" alignment="CENTER" spacing="4" styleClass="signup-footer">
         <padding>
           <Insets bottom="28" />
         </padding>
       </HBox>
    </VBox>
  </VBox>
</StackPane>
