<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<StackPane styleClass="signup-root" stylesheets="@../styles/lupapassword.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.projectuas.LupaPasswordController">
  <children>
    <Rectangle arcHeight="400" arcWidth="400" height="400" styleClass="bg-circle-1" width="400" />
    <Rectangle arcHeight="300" arcWidth="300" height="300" styleClass="bg-circle-2" width="300" StackPane.alignment="BOTTOM_RIGHT" />
    <VBox maxHeight="768.0" maxWidth="440" prefHeight="768.0" prefWidth="400.0" spacing="0" styleClass="signup-card" StackPane.alignment="CENTER">
      <children>
        <!-- HEADER -->
        <VBox alignment="CENTER" spacing="6" styleClass="signup-header">
          <padding>
            <Insets bottom="20" left="36" right="36" top="30" />
          </padding>
          <children>
            <Label styleClass="signup-logo" text="🔐" />
            <Label styleClass="signup-title" text="Reset Password" />
            <Label styleClass="signup-sub" text="Setel ulang password akun Anda" />
          </children>
        </VBox>
        <!-- FORM -->
        <VBox spacing="14" styleClass="signup-form">
          <padding>
            <Insets bottom="28" left="36" right="36" top="20" />
          </padding>
          <children>
            <!-- ROLE -->
            <Label styleClass="field-label" text="Role" />
            <ComboBox fx:id="cmbRole" maxWidth="Infinity" prefHeight="229.0" prefWidth="326.0" promptText="Pilih Role" styleClass="form-combo" VBox.vgrow="ALWAYS" />
            <!-- INPUT DINAMIS (Email / Username Lama) -->
            <Label fx:id="lblinput" styleClass="field-label" text="Masukkan Email Anda" />
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="field-box" VBox.vgrow="ALWAYS">
              <children>
                <Label fx:id="iconInput" styleClass="field-icon" text="📧" />
                <TextField fx:id="tfinput" promptText="Masukkan Email Anda" styleClass="field-input" HBox.hgrow="ALWAYS" />
              </children>
            </HBox>
            <!-- USERNAME BARU -->
            <Label styleClass="field-label" text="Username Baru" />
            <HBox alignment="CENTER_LEFT" prefHeight="52.0" spacing="10" styleClass="field-box">
              <children>
                <Label styleClass="field-icon" text="👤" />
                <TextField fx:id="tfUsernameBaru" promptText="Masukkan username baru" styleClass="field-input" HBox.hgrow="ALWAYS" />
              </children>
            </HBox>
            <!-- PASSWORD BARU -->
            <Label styleClass="field-label" text="Password Baru" />
            <HBox alignment="CENTER_LEFT" prefHeight="52.0" spacing="10" styleClass="field-box">
              <children>
                <Label styleClass="field-icon" text="🔒" />
                <PasswordField fx:id="tfPasswordBaru" promptText="Masukkan password baru" styleClass="field-input" HBox.hgrow="ALWAYS" />
                <TextField fx:id="tfPasswordBaruVisible" managed="false" promptText="Masukkan password baru" styleClass="field-input" visible="false" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnEyeBaru" onAction="#togglePasswordBaru" styleClass="btn-eye" text="👁" />
              </children>
            </HBox>
            <!-- KONFIRMASI PASSWORD -->
            <Label styleClass="field-label" text="Konfirmasi Password Baru" />
            <HBox alignment="CENTER_LEFT" prefHeight="52.0" spacing="10" styleClass="field-box">
              <children>
                <Label styleClass="field-icon" text="🔒" />
                <PasswordField fx:id="tfKonfirmasi" promptText="Ulangi password baru" styleClass="field-input" HBox.hgrow="ALWAYS" />
                <TextField fx:id="tfKonfirmasiVisible" managed="false" promptText="Ulangi password baru" styleClass="field-input" visible="false" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnEyeKonfirmasi" onAction="#toggleKonfirmasi" styleClass="btn-eye" text="👁" />
              </children>
            </HBox>
            <!-- TOMBOL RESET -->
            <Button fx:id="btnReset" maxWidth="Infinity" onAction="#handleReset" styleClass="login-btn" text="🔄 Reset Password" />
            <!-- TOMBOL KEMBALI -->
            <Button maxWidth="Infinity" onAction="#handleKembali" styleClass="btn-kembali" text="← Kembali ke Login" />
          </children>
        </VBox>
      </children>
    </VBox>
  </children>
</StackPane>
